{
  "name": "cupid-engineered-llm-router",
  "version": "0.1.0",
  "description": "Production-ready engineered LLM router for Cupid AI IDE",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "ingest": "tsx src/index.ts ingest",
    "reindex": "tsx src/index.ts reindex",
    "classify": "tsx src/cli/cli.ts classify",
    "optimize": "tsx src/cli/cli.ts optimize",
    "recommend": "tsx src/cli/cli.ts recommend",
    "engineer": "tsx src/cli/cli.ts engineer",
    "eval:recommendation": "tsx src/eval/evalRunner.ts recommendation",
    "eval:prompt-optimization": "tsx src/eval/evalRunner.ts prompt-optimization",
    "eval:all": "tsx src/eval/evalRunner.ts all",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "better-sqlite3": "^12.9.0",
    "commander": "^12.0.0",
    "csv-parse": "^5.5.5",
    "drizzle-orm": "^0.30.10",
    "fastify": "^4.26.2",
    "js-tiktoken": "^1.0.21",
    "node-fetch": "^3.3.2",
    "yaml": "^2.4.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.12.7",
    "@vitest/coverage-v8": "^1.5.0",
    "drizzle-kit": "^0.21.2",
    "tsx": "^4.7.3",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.32.0+sha512.9b2634bb3fed5601c33633f2d92593f506270a3963b8c51d2b2d6a828da615ce4e9deebef9614ccebbc13ac8d3c0f9c9ccceb583c69c8578436fa477dbb20d70"
}
