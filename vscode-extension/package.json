{
  "name": "cupid-ai-router",
  "displayName": "Cupid AI Router",
  "description": "Cursor-style AI chat with intelligent multi-model routing — saves 90%+ cost vs always using Opus",
  "version": "0.2.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["AI", "Other"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cupid-sidebar",
          "title": "Cupid AI",
          "icon": "$(robot)"
        }
      ]
    },
    "views": {
      "cupid-sidebar": [
        {
          "type": "webview",
          "id": "cupid.chatView",
          "name": "Chat",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "commands": [
      {
        "command": "cupid.openChat",
        "title": "Cupid: Open Chat",
        "icon": "$(robot)"
      },
      {
        "command": "cupid.askWithSelection",
        "title": "Cupid: Ask about selected code",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "cupid.showStats",
        "title": "Cupid: Show session stats"
      },
      {
        "command": "cupid.resetSession",
        "title": "Cupid: Reset session memory (CPL)"
      },
      {
        "command": "cupid.configureEndpoint",
        "title": "Cupid: Configure backend endpoint"
      },
      {
        "command": "cupid.moveToRight",
        "title": "Cupid: Move chat to right (Secondary Side Bar)"
      }
    ],
    "keybindings": [
      {
        "command": "cupid.openChat",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k"
      },
      {
        "command": "cupid.askWithSelection",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "editorHasSelection"
      }
    ],
    "configuration": {
      "title": "Cupid AI Router",
      "properties": {
        "cupid.backendUrl": {
          "type": "string",
          "default": "http://localhost:3300",
          "description": "URL of the Cupid backend server"
        },
        "cupid.userMode": {
          "type": "string",
          "enum": ["cost_saving", "balanced", "max_quality"],
          "default": "balanced",
          "description": "cost_saving aggressively prefers cheap models; max_quality always uses strong models"
        },
        "cupid.routingMode": {
          "type": "string",
          "enum": ["rule_based", "llm_assisted"],
          "default": "llm_assisted",
          "description": "How tasks are classified before routing"
        },
        "cupid.autoMoveToRight": {
          "type": "boolean",
          "default": true,
          "description": "On first activation, move the Cupid chat to the right Secondary Side Bar (Cursor-style)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "package": "vsce package"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
