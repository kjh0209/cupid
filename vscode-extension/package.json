{
  "name": "cupid-ai-router",
  "displayName": "Cupid AI Router",
  "description": "Cursor-style AI chat with intelligent multi-model routing — saves 90%+ cost vs always using Opus",
  "version": "0.3.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["AI", "Other"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cupid-sidebar",
          "title": "Cupid AI",
          "icon": "$(robot)"
        }
      ]
    },
    "views": {
      "cupid-sidebar": [
        {
          "type": "webview",
          "id": "cupid.chatView",
          "name": "Chat",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "commands": [
      {
        "command": "cupid.openChat",
        "title": "Cupid: Open Chat",
        "icon": "$(robot)"
      },
      {
        "command": "cupid.askWithSelection",
        "title": "Cupid: Ask about selected code",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "cupid.showStats",
        "title": "Cupid: Show session stats"
      },
      {
        "command": "cupid.resetSession",
        "title": "Cupid: Reset session memory (CPL)"
      },
      {
        "command": "cupid.configureEndpoint",
        "title": "Cupid: Configure backend endpoint"
      },
      {
        "command": "cupid.moveToRight",
        "title": "Cupid: Move chat to right (Secondary Side Bar)"
      },
      {
        "command": "cupid.inlineEdit",
        "title": "Cupid: Inline Edit at cursor (Ctrl+K)",
        "icon": "$(edit)"
      },
      {
        "command": "cupid.acceptChanges",
        "title": "Cupid: Accept proposed changes"
      },
      {
        "command": "cupid.rejectChanges",
        "title": "Cupid: Reject proposed changes"
      }
    ],
    "keybindings": [
      {
        "command": "cupid.openChat",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k"
      },
      {
        "command": "cupid.askWithSelection",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "editorHasSelection"
      },
      {
        "command": "cupid.inlineEdit",
        "key": "ctrl+k",
        "mac": "cmd+k",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Cupid AI Router",
      "properties": {
        "cupid.backendUrl": {
          "type": "string",
          "default": "http://localhost:3300",
          "description": "URL of the Cupid backend server. Default: http://localhost:3300. Run `pnpm dev` in the cupid backend folder to start it."
        },
        "cupid.userMode": {
          "type": "string",
          "enum": ["cost_saving", "balanced", "max_quality"],
          "enumDescriptions": [
            "Aggressively prefers cheap models (GPT-4o-mini, Haiku). Great for simple edits and explanations.",
            "Balanced cost and quality. Routes based on task complexity. Recommended for most users.",
            "Always uses the strongest available model. Best output, highest cost."
          ],
          "default": "balanced",
          "description": "Controls which model tier Cupid selects. cost_saving < balanced < max_quality."
        },
        "cupid.routingMode": {
          "type": "string",
          "enum": ["rule_based", "llm_assisted"],
          "enumDescriptions": [
            "Fast heuristic routing — instant, no extra cost. Good for well-defined task types.",
            "LLM-based routing — slightly slower, slightly more expensive, but smarter task classification."
          ],
          "default": "llm_assisted",
          "description": "How Cupid classifies your task before routing to a model."
        },
        "cupid.autoMoveToRight": {
          "type": "boolean",
          "default": true,
          "description": "On first activation, move the Cupid chat to the right Secondary Side Bar (Cursor-style layout)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "package": "vsce package"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
