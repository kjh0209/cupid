# ============================================================
# Cupid Engineered LLM Router - Environment Variables
# ============================================================
# Copy this to .env and fill in the values you have.
# All LLM API keys are optional - the router works without them
# using rule-based classification and deterministic scoring.
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ────────────────────────────────────────────────
DATABASE_PATH=./cupid_router.db

# ── LLM API Keys (optional but recommended for LLM-enhanced classification) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# ── LLM for classification/optimization (optional) ──────────
# If set, the classifier will use this model as a secondary signal.
# Leave blank to use pure rule-based classification.
CLASSIFICATION_LLM_MODEL=anthropic/claude-haiku-4-5
OPTIMIZATION_LLM_MODEL=anthropic/claude-haiku-4-5

# ── Data Collection ─────────────────────────────────────────
# LiteLLM model cost map URL (default below)
LITELLM_COST_MAP_URL=https://raw.githubusercontent.com/BerriAI/litellm/main/model_prices_and_context_window.json

# OpenRouter Models API
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Embeddings (optional, for semantic RAG) ─────────────────
# If not set, BM25 keyword fallback is used.
# Options: openai | anthropic | none
EMBEDDING_PROVIDER=none
EMBEDDING_MODEL=text-embedding-3-small

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=pretty

# ── Evaluation ──────────────────────────────────────────────
EVAL_OUTPUT_DIR=./reports
